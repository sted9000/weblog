---
import { render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

type AnyEntry = CollectionEntry<'blog'> | CollectionEntry<'links'>;

interface Props {
  entry: AnyEntry;
  type: 'blog' | 'links';
  full?: boolean;
  hideDate?: boolean;
}

const { entry, type, full = false, hideDate = false } = Astro.props;
const base = import.meta.env.BASE_URL;
const permalink = `${base}/${type}/${entry.id}`;
const date = entry.data.date;
const dateStr = date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
const { Content } = await render(entry);

const typeLabels: Record<string, string> = {
  blog: 'Blog',
  links: 'Link',
};

const isLink = type === 'links';
const linkData = isLink ? (entry.data as CollectionEntry<'links'>['data']) : null;
const titleHref = isLink ? linkData!.url : permalink;
---
<article class={`entry ${isLink ? 'is-link' : ''}`}>
  <div class="entry-header">
    <h2>
      {full && !isLink ? entry.data.title : <a href={titleHref}>{entry.data.title}</a>}
    </h2>
    {!isLink && <span class="type-badge">{typeLabels[type]}</span>}
  </div>
  {(!hideDate || (isLink && linkData!.authors && linkData!.authors.length > 0)) && (
    <div class="meta">
      {!hideDate && (
        <a href={permalink}><time datetime={date.toISOString()}>{dateStr}</time></a>
      )}
      {isLink && linkData!.authors && linkData!.authors.length > 0 && (
        <span>{!hideDate && ' · '}{linkData!.authors.join(', ')}</span>
      )}
    </div>
  )}

  {isLink && linkData!.quote && (
    <blockquote class="link-quote">{linkData!.quote}</blockquote>
  )}

  <div class="entry-body">
    <Content />
  </div>

  {isLink && linkData!.via && (
    <p class="via">
      Via {linkData!.via.url
        ? <a href={linkData!.via.url}>{linkData!.via.name}</a>
        : linkData!.via.name}
    </p>
  )}

  {entry.data.tags.length > 0 && (
    <div class="tags">
      {entry.data.tags.map((t: string) => (
        <a class="tag" href={`${base}/tags/${t}`}>{t}</a>
      ))}
    </div>
  )}
</article>
