---
import Base from '../layouts/Base.astro';
import Entry from '../components/Entry.astro';
import { getAllItems, type StreamItem } from '../lib/stream';

const items = await getAllItems();

const groups: { key: string; label: string; iso: string; items: StreamItem[] }[] = [];
const groupIndex = new Map<string, number>();
for (const item of items) {
  const d = item.entry.data.date;
  const key = `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`;
  const label = d.toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
  let idx = groupIndex.get(key);
  if (idx === undefined) {
    idx = groups.length;
    groupIndex.set(key, idx);
    groups.push({ key, label, iso: d.toISOString(), items: [] });
  }
  groups[idx].items.push(item);
}
---
<Base>
  {groups.length === 0 && <p>Nothing posted yet.</p>}
  {groups.map((group) => (
    <section class="day-group">
      <h2 class="day-heading"><time datetime={group.iso}>{group.label}</time></h2>
      {group.items.map(({ entry, type }) => (
        <Entry entry={entry} type={type} hideDate />
      ))}
    </section>
  ))}
</Base>
